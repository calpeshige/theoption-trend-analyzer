{
  "manifest_version": 3,
  "name": "Theoption Trading System (開発用)",
  "version": "5.8.13",
  "description": "TheOptionのトレーディング画面で多次元指標分析とAI機械学習を統合し、超短期取引(15秒〜5分)の高精度予測を提供します",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://jp.theoption.com/*",
    "https://theoption.com/*",
    "https://platformapi.theoption.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://jp.theoption.com/trading*",
        "https://theoption.com/trading*"
      ],
      "js": [
        "license-manager.js",
        "trend-analyzer-engine.js",
        "multi-indicator-system.js",
        "price-pattern-analyzer.js",
        "technical-timeseries-analyzer.js",
        "detailed-segment-analyzer.js",
        "segment-similarity-calculator.js",
        "db-manager.js",
        "machine-learning-system.js",
        "pattern-stratification-system.js",
        "signal-enhancer-system.js",
        "enhanced-technical-analysis.js",
        "advanced-signal-engine.js",
        "theoption-analyzer.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sound/*.mp3",
        "scripts/ml-worker.js",
        "detailed-segment-analyzer.js",
        "segment-similarity-calculator.js",
        "pattern-matching-system.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "extension_ids": []
    }
  ]
}